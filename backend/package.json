{
  "name": "clinic-booking-backend",
  "version": "1.0.0",
  "description": "Backend API for a distributed clinic appointment booking system.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test:e2e": "set NODE_ENV=test&& node src/scripts/e2eSmokeTest.js",
    "seed": "node src/seed/seed.js",
    "seed:demo": "node src/seed/seedDemoData.js",
    "seed:specialties": "node src/seed/seedSpecialties.js",
    "seed:service-packages": "node src/seed/seedServicePackages.js",
    "seed:articles": "node src/seed/seedArticles.js",
    "migrate:clinic-doctor-codes": "node src/scripts/fixDoctorClinicCodes.js",
    "fix:doctor-clinic-codes": "node src/scripts/fixDoctorClinicCodes.js",
    "sync:follow-ups": "node src/scripts/syncFollowUpStatuses.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.9",
    "pdfkit": "^0.19.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
